# ============================================================
#  TEMPLATE ONLY — do NOT put real values in this file.
#  This file is safe to commit to git and is meant to show
#  which variables exist. Real secrets go in .env (gitignored).
# ============================================================

# Private key of the EOA that controls your Polymarket proxy wallet.
# Export it from Polymarket (Settings -> Wallet -> Export private key).
# 64 hex chars after the 0x.
POLYMARKET_PRIVATE_KEY=0xREPLACE_ME_WITH_YOUR_PRIVATE_KEY

# Your Polymarket public address (shown on profile / deposit screen).
# This is the wallet that holds your USDC. 40 hex chars after 0x.
POLYMARKET_FUNDER_ADDRESS=0xREPLACE_ME_WITH_YOUR_FUNDER_ADDRESS

# Signature type:
#   1 = email/Magic account (POLY_PROXY)        <- use this for email accounts
#   2 = browser wallet via Gnosis Safe
#   0 = plain EOA (no proxy, direct Metamask-style trading)
POLYMARKET_SIGNATURE_TYPE=1

# Optional: pre-derived CLOB API credentials. Leave empty unless you know
# you need them — the bot derives them from the private key on each run.
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
